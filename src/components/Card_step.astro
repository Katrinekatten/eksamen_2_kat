<style>
  .card_step {
    background-color: var(--red);
    margin: 25px 24px;
    border-radius: var(--btn_border-mobile);
    display: grid;
    grid-template-columns: 1fr 1fr;
    padding: 2rem;
    color: var(--white);
    text-align: left;
  }
  .card_step_div {
    display: flex;
    flex-direction: column;
  }
  .card_mobile {
    height: 111px;
    width: auto;
    fit: cover;
    display: flex;
    align-self: center;
    padding-top: 30px;
  }
  #card_desktop {
    display: none;
  }
  #p_desktop {
    display: none;
  }
  #card_step_btn_desktop {
    display: none;
  }
  #h1_desktop {
    display: none;
  }
  .card_step_btn {
    background-color: #1e1e1e;
    color: var(--white);
    text-decoration: none;
    font-size: var(--button-mobile);
    font-weight: 700;
    padding: var(--btn_padding);
    border-radius: var(--btn_border-mobile);
    text-align: center;
    align-self: flex-end;
  }
  #dk_logo {
    height: 21.33px;
    display: flex;
    flex-direction: row;
    align-self: flex-end;
  }
  #h1_mobile {
    font-weight: 600;
    font-size: var(--h1-mobile);
  }
  #p_mobile {
    font-weight: 500;
    font-size: var(--p-mobile);
  }
  /* DESKTOP */
  @media (min-width: 1024px) {
    #p_mobile {
      display: none;
      margin: 0 0 1rem 0;
    }
    .card_mobile {
      display: none;
    }
    #h1_mobile {
      display: none;
      margin: 0 0 0.5rem 0; 
    }
    #p_desktop {
      display: block;
      font-weight: 300;
      font-size: var(--p);
    margin-top: 0.5rem; 
    }
    #card_desktop {
      display: block;
      display: flex;
      align-self: center;
    }
    #h1_desktop {
      display: block;
    }
    .card_step {
      column-gap: 2rem;
      margin: 64px 80px;
      padding: 2rem;
    }
    .card_step_btn {
      font-size: var(--button);
      font-weight: 700;
      align-self: flex-start;
      padding: var(--btn_padding);
      align-self: flex-start; 
    margin-top: 1rem; 
    }
    #card_step_btn_desktop {
      display: block;
    }
    #card_step_btn_mobile {
      display: none;
    }
    h1 {
      font-size: 36px;
      font-weight: 700;
    }

    #dk_logo {
      height: 63px;
      display: flex;
      flex-direction: row;
      align-self: flex-end;
    }
  }
</style>
