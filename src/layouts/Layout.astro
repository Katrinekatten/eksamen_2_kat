---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const { title = "Mit site", description = "Standard beskrivelse" } = Astro.props;
---

<!doctype html>
<html lang="da">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/x-icon" href="public/favicon_transparent.ico">
    <link rel="icon" href="/favicon.ico" />
    <title>{title}</title>

    <meta name="description" content={description} />
      <link
    rel="preload"
    href="/fonts/Raleway-VariableFont_wght.woff2"
    as="font"
    type="font/woff2"
    crossorigin
  />
  </head>
  <body>
    <Header />
    <slot />
    <Footer />
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
  }
</style>